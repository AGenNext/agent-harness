# agent-harness Configuration

# ===== LLM Provider =====
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ===== GitHub =====
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ===== Notification =====
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
CODE_ASSIST_HOOK=
CODE_REVIEW_HOOK=
CODE_TESTER_HOOK=
CODE_DEPLOY_HOOK=

# ===== Admin =====
ADMIN_USER=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=change-me

# Roles: admin, developer, viewer
DEFAULT_ROLE=developer

# ===== Security =====
REQUIRE_APPROVAL_FOR_PROD=true
ALLOWED_ENVS=dev,staging,prod

# ===== Docker =====
DOCKER_HOST=/var/run/docker.sock

# ===== Optional =====
AUTO_MERGE_ENABLED=true
DEBUG=false
HARNESS_SECRET=change-me